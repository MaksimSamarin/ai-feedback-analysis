      "models_env": "OPENAI_MODELS"
    },
    "ollama": {
      "label": "Ollama (внешний хост)",
      "models": [
        "llama3.1:latest"
      ],
      "base_url_env": "OLLAMA_BASE_URL",
      "base_url_default": "",
      "models_env": "OLLAMA_MODELS"
    }
  }
}
